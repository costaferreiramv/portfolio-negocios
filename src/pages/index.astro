---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { capaDe, precoBR } from '../lib/fotos';
import { EIXOS, eixoOcultaBairro } from '../lib/eixos';
import { imagemZonaSul, waLink } from '../lib/site';
import { DESTAQUES } from '../lib/destaques';
import retratoMarcus from '../assets/marcus/marcus-retrato.jpg';
import familiaMarcus from '../assets/marcus/marcus-familia.jpg';
import aereaZonaSul from '../assets/zonasul/zona-sul-home-bg.png';

const imoveis = (await getCollection('imoveis')).sort(
  (a, b) => b.data.publicadoEm.getTime() - a.data.publicadoEm.getTime()
);

const tipoLabel: Record<string, string> = {
  apartamento: 'Apartamento', casa: 'Casa', cobertura: 'Cobertura', lote: 'Lote',
  'sala-comercial': 'Sala comercial', 'casa-comercial': 'Casa comercial',
  area: 'Área', fazenda: 'Fazenda', rancho: 'Rancho', sitio: 'Sítio',
};

// Tipos de imóvel que o site realmente tem hoje — usados só na busca por filtro
// (a Home free-text reconhece mais sinônimos, mas o menu mostra só o que existe).
const FILTRO_TIPOS = [
  { valor: 'apartamento', rotulo: 'Apartamento' },
  { valor: 'casa', rotulo: 'Casa' },
  { valor: 'casa-condominio', rotulo: 'Casa em condomínio' },
  { valor: 'cobertura', rotulo: 'Cobertura' },
  { valor: 'lote', rotulo: 'Lote' },
  { valor: 'comercial', rotulo: 'Comercial' },
];

const FILTRO_AREAS = [
  { valor: 'ate-50', rotulo: 'Até 50 m²', min: '', max: '50' },
  { valor: '50-75', rotulo: '50 até 75 m²', min: '50', max: '75' },
  { valor: '75-150', rotulo: '75 até 150 m²', min: '75', max: '150' },
  { valor: '150-250', rotulo: '150 até 250 m²', min: '150', max: '250' },
  { valor: '250-350', rotulo: '250 até 350 m²', min: '250', max: '350' },
  { valor: 'acima-350', rotulo: 'Acima de 350 m²', min: '350', max: '' },
];

const FILTRO_PRECOS = [
  { valor: '600-800', rotulo: 'De R$ 600.000 até R$ 800.000', min: '600000', max: '800000' },
  { valor: '800-1000', rotulo: 'De R$ 800.000 até R$ 1.000.000', min: '800000', max: '1000000' },
  { valor: '1000-1200', rotulo: 'De R$ 1.000.000 até R$ 1.200.000', min: '1000000', max: '1200000' },
  { valor: '1200-1400', rotulo: 'De R$ 1.200.000 até R$ 1.400.000', min: '1200000', max: '1400000' },
  { valor: '1400-1600', rotulo: 'De R$ 1.400.000 até R$ 1.600.000', min: '1400000', max: '1600000' },
  { valor: '1600-2000', rotulo: 'De R$ 1.600.000 até R$ 2.000.000', min: '1600000', max: '2000000' },
  { valor: '2000-3000', rotulo: 'De R$ 2.000.000 até R$ 3.000.000', min: '2000000', max: '3000000' },
  { valor: 'acima-3000', rotulo: 'Acima de R$ 3.000.000', min: '3000000', max: '' },
];

// nomes de empreendimentos/prédios dentro do Complexo Vinhedos — não são bairros,
// não devem aparecer soltos no filtro (o eixo "Complexo Vinhedos" continua selecionável)
const EXCLUIR_DO_FILTRO_BAIRRO = new Set([
  'Pátio Vinhedos', 'Triad', 'Sense', 'Duo', 'Arven', 'Allma', 'Mellie', 'Torres do Sul', 'Ambar',
  'Vinhedos', // não é bairro — só o eixo "Complexo Vinhedos" fica na lista
]);

// mantém a ordem definida em DESTAQUES, ignora silenciosamente código que não exista mais
const imoveisDestaque = DESTAQUES
  .map((cod) => imoveis.find((im) => im.data.codigo === cod))
  .filter((im) => im !== undefined);

// Dados de busca embutidos: cada imóvel com a capa já otimizada (para o JS montar os cards).
const dadosBusca = await Promise.all(
  imoveis.map(async (im) => {
    const capa = await getImage({
      src: capaDe(im.data.fotos, im.data.capa),
      width: 720,
      widths: [440, 720],
      format: 'webp',
    });
    return {
      slug: im.id,
      codigo: im.data.codigo || '',
      titulo: im.data.titulo,
      tipo: im.data.tipo,
      // bairro só embarcado quando o eixo permite exibi-lo — não vaza no HTML dos condomínios
      bairro: eixoOcultaBairro(im.data.eixo) ? '' : im.data.bairro,
      eixo: im.data.eixo,
      ocultaBairro: eixoOcultaBairro(im.data.eixo),
      condominio: !!im.data.condominio,
      preco: im.data.preco,
      area: im.data.areaUtil,
      dormitorios: im.data.dormitorios,
      suites: im.data.suites,
      vagas: im.data.vagas,
      capa: capa.src,
      url: `/imovel/${im.id}/`,
    };
  })
);

// bairros/áreas que a busca reconhece (dos eixos + dos imóveis cadastrados).
// Imóveis de eixo com bairro oculto não contribuem seu bairro — nem como termo reconhecido.
const bairrosConhecidos = Array.from(
  new Set([
    ...EIXOS.flatMap((e) => e.areas),
    ...imoveis.filter((i) => !eixoOcultaBairro(i.data.eixo)).map((i) => i.data.bairro),
  ])
);

// mesma lista, mas sem os nomes de empreendimentos/prédios — usada só no menu do filtro
const bairrosFiltro = bairrosConhecidos.filter((b) => !EXCLUIR_DO_FILTRO_BAIRRO.has(b));

// eixos (id + áreas) para a busca resolver "perto de X" pela região, não só pelo bairro exato
const eixosBusca = EIXOS.map((e) => ({ id: e.id, nome: e.curto, areas: e.areas }));

const WA_BUSCA = waLink('Olá Marcus, não encontrei no site exatamente o que procuro. Pode me ajudar?');

// eixos com imagem otimizada
const eixosImg = await Promise.all(
  EIXOS.map(async (e) => ({
    ...e,
    img: await getImage({ src: imagemZonaSul(e.imagem), width: 720, widths: [440, 720], format: 'webp' }),
  }))
);
---

<Base
  title="Portfólio Negócios Imobiliários — Imóveis à venda na Zona Sul de Uberlândia"
  description="Curadoria de imóveis à venda na Zona Sul de Uberlândia, apresentada diretamente pelo corretor Marcus Vinícius. Busque em linguagem natural e fale direto com o corretor."
>
  <!-- HERO: forma de trabalhar + busca livre -->
  <section class="hero-busca">
    <div class="hero-bg">
      <Image src={aereaZonaSul} alt="Vista aérea da Zona Sul de Uberlândia" widths={[900, 1400, 2048]} sizes="100vw" loading="eager" fetchpriority="high" />
      <div class="hero-veu2"></div>
    </div>
    <div class="wrap hero-busca-in">
      <span class="rotulo rotulo-ciano reveal">Zona Sul de Uberlândia</span>
      <h1 class="reveal hero-busca-titulo">Imóveis selecionados, escolhas inteligentes.</h1>
      <p class="lede reveal">
        Nossa curadoria elimina o ruído, focando no que é essencial para você. Menos busca, mais acerto. Escreva aqui o que procura, com suas palavras, clique em buscar e surpreenda-se.
      </p>

      <form class="busca reveal" id="form-busca" role="search">
        <div class="busca-campo">
          <input
            type="text" id="q" name="q" autocomplete="off"
            placeholder="Ex.: casa de 3 quartos na Zona Sul, entre 870 mil e 1,2 milhões, 120 m²+"
            aria-label="Descreva o imóvel que procura"
          />
          <span class="busca-placeholder-mob" aria-hidden="true">Ex.: casa de 3 quartos na Zona Sul, entre 870 mil e 1,2 milhões, 120 m²+</span>
        </div>
        <button type="submit">Buscar</button>
      </form>
      <p class="busca-dica reveal">Escreva livremente: tipo, bairro ou eixo, nº de quartos/suítes, faixa de preço e área.</p>
      <button type="button" id="toggle-filtro" class="busca-toggle-filtro reveal">Buscar por filtro <span aria-hidden="true">▾</span></button>

      <form class="busca-filtros" id="form-filtros" hidden>
        <div class="busca-filtros-grade">
          <div class="campo campo-dropdown">
            <label>Pretensão</label>
            <button type="button" class="dropdown-btn" disabled>
              <span>Comprar</span>
            </button>
          </div>

          <div class="campo campo-dropdown" data-dropdown id="campo-f-tipo">
            <label id="lbl-f-tipo">Tipo de imóvel</label>
            <button type="button" class="dropdown-btn" data-dropdown-btn aria-haspopup="listbox" aria-expanded="false" aria-labelledby="lbl-f-tipo">
              <span data-dropdown-label>Todos os tipos</span>
              <span class="seta" aria-hidden="true">▾</span>
            </button>
            <div class="dropdown-painel" data-dropdown-painel hidden role="listbox">
              <button type="button" class="dropdown-opcao ativo" data-valor="">Todos os tipos</button>
              {FILTRO_TIPOS.map((t) => (
                <button type="button" class="dropdown-opcao" data-valor={t.valor}>{t.rotulo}</button>
              ))}
            </div>
          </div>

          <div class="campo campo-dropdown" data-dropdown id="campo-f-local">
            <label id="lbl-f-local">Bairro ou eixo</label>
            <button type="button" class="dropdown-btn" data-dropdown-btn aria-haspopup="listbox" aria-expanded="false" aria-labelledby="lbl-f-local">
              <span data-dropdown-label>Todos os bairros e eixos</span>
              <span class="seta" aria-hidden="true">▾</span>
            </button>
            <div class="dropdown-painel" data-dropdown-painel hidden role="listbox">
              <button type="button" class="dropdown-opcao ativo" data-valor="">Todos os bairros e eixos</button>
              <span class="dropdown-grupo">Eixos</span>
              {EIXOS.map((e) => (
                <button type="button" class="dropdown-opcao" data-valor={e.id} data-tipo="eixo">{e.curto}</button>
              ))}
              <span class="dropdown-grupo">Bairros</span>
              {bairrosFiltro.map((b) => (
                <button type="button" class="dropdown-opcao" data-valor={b} data-tipo="bairro">{b}</button>
              ))}
            </div>
          </div>

          <div class="campo campo-dropdown" data-dropdown id="campo-f-preco">
            <label id="lbl-f-preco">Preço</label>
            <button type="button" class="dropdown-btn" data-dropdown-btn aria-haspopup="listbox" aria-expanded="false" aria-labelledby="lbl-f-preco">
              <span data-dropdown-label>Todas as faixas</span>
              <span class="seta" aria-hidden="true">▾</span>
            </button>
            <div class="dropdown-painel" data-dropdown-painel hidden role="listbox">
              <button type="button" class="dropdown-opcao ativo" data-valor="" data-min="" data-max="">Todas as faixas</button>
              {FILTRO_PRECOS.map((p) => (
                <button type="button" class="dropdown-opcao" data-valor={p.valor} data-min={p.min} data-max={p.max}>{p.rotulo}</button>
              ))}
            </div>
          </div>

          <div class="campo campo-dropdown" data-dropdown id="campo-f-area">
            <label id="lbl-f-area">Área</label>
            <button type="button" class="dropdown-btn" data-dropdown-btn aria-haspopup="listbox" aria-expanded="false" aria-labelledby="lbl-f-area">
              <span data-dropdown-label>Qualquer área</span>
              <span class="seta" aria-hidden="true">▾</span>
            </button>
            <div class="dropdown-painel" data-dropdown-painel hidden role="listbox">
              <button type="button" class="dropdown-opcao ativo" data-valor="" data-min="" data-max="">Qualquer área</button>
              {FILTRO_AREAS.map((a) => (
                <button type="button" class="dropdown-opcao" data-valor={a.valor} data-min={a.min} data-max={a.max}>{a.rotulo}</button>
              ))}
            </div>
          </div>

          <div class="campo">
            <label>Quartos</label>
            <div class="chips" data-chips="dorm" data-valor="">
              <button type="button" class="chip ativo" data-valor="">Todos</button>
              <button type="button" class="chip" data-valor="1">1+</button>
              <button type="button" class="chip" data-valor="2">2+</button>
              <button type="button" class="chip" data-valor="3">3+</button>
              <button type="button" class="chip" data-valor="4">4+</button>
            </div>
          </div>
          <div class="campo">
            <label>Suítes</label>
            <div class="chips" data-chips="suite" data-valor="">
              <button type="button" class="chip ativo" data-valor="">Todas</button>
              <button type="button" class="chip" data-valor="1">1+</button>
              <button type="button" class="chip" data-valor="2">2+</button>
              <button type="button" class="chip" data-valor="3">3+</button>
              <button type="button" class="chip" data-valor="4">4+</button>
            </div>
          </div>
          <div class="campo">
            <label>Vagas</label>
            <div class="chips" data-chips="vaga" data-valor="">
              <button type="button" class="chip ativo" data-valor="">Todas</button>
              <button type="button" class="chip" data-valor="1">1+</button>
              <button type="button" class="chip" data-valor="2">2+</button>
              <button type="button" class="chip" data-valor="3">3+</button>
              <button type="button" class="chip" data-valor="4">4+</button>
            </div>
          </div>
          <div class="campo">
            <label>Condomínio horizontal</label>
            <div class="chips" data-chips="cond" data-valor="">
              <button type="button" class="chip ativo" data-valor="">Indiferente</button>
              <button type="button" class="chip" data-valor="sim">Sim</button>
              <button type="button" class="chip" data-valor="nao">Não</button>
            </div>
          </div>
        </div>
        <div class="busca-filtros-acoes">
          <button type="button" id="voltar-busca-livre" class="btn btn-vazado">← Busca livre</button>
          <button type="submit" class="btn btn-solido">Encontrar imóvel</button>
        </div>
      </form>
    </div>
  </section>

  <!-- RESULTADOS da busca (preenchidos por JS) -->
  <section id="resultados" hidden>
    <div class="wrap">
      <div class="res-cab">
        <div>
          <span class="rotulo">Resultado da busca</span>
          <h2 id="res-titulo">Imóveis encontrados</h2>
          <p id="res-interp" class="res-interp"></p>
        </div>
        <button id="limpar" class="btn btn-vazado" type="button">Limpar busca</button>
      </div>
      <div class="grade" id="res-grade"></div>
      <div id="res-vazio" class="res-vazio" hidden>
        <p>Não achei um imóvel que bata exatamente com isso na seleção atual — mas o estoque muda o tempo todo. Me conte o que procura que eu busco pra você.</p>
        <a class="btn-wa" href={WA_BUSCA} target="_blank" rel="noopener">Falar com o Marcus</a>
      </div>
    </div>
  </section>

  <!-- ESPECIALIDADE: Zona Sul e seus eixos -->
  <section id="zonasul-home">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="rotulo rotulo-ciano">Nossa especialidade</span>
        <h2>A Zona Sul em foco.</h2>
        <p>Nos especializamos na região da Zona Sul, segmentamos cada parte e conhecemos a fundo cada imóvel do portfólio para proporcionar a cada vendedor e comprador a melhor experiência de atendimento.</p>
      </div>
      <div class="eixos-img">
        {eixosImg.map((e) => (
          <a class="eixo-card reveal" href={`/zona-sul/${e.id}/`}>
            <div class="eixo-foto">
              <img src={e.img.src} srcset={e.img.srcSet.attribute} sizes="(max-width:760px) 90vw, 380px" alt={`Zona Sul — ${e.nome}`} loading="lazy" />
            </div>
            <div class="eixo-card-corpo">
              <h3>{e.nome}</h3>
              <span class="eixo-ir">Ver imóveis do eixo →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="reveal" style="margin-top:32px">
        <a class="btn btn-vazado" href="/zona-sul/">Entender a divisão por eixos</a>
      </div>
    </div>
  </section>

  <!-- DESTAQUES E OPORTUNIDADES -->
  {imoveisDestaque.length > 0 && (
    <section id="destaques">
      <div class="wrap">
        <div class="sec-head reveal">
          <span class="rotulo rotulo-ciano">Curadoria do mês</span>
          <h2>Destaques e Oportunidades</h2>
          <p>Opções que merecem o olhar atento de quem busca uma oportunidade na Zona Sul</p>
        </div>
        <div class="grade">
          {imoveisDestaque.map((imovel) => (
            <a class="card reveal" href={`/imovel/${imovel.id}/`}>
              <div class="foto">
                <Image
                  src={capaDe(imovel.data.fotos, imovel.data.capa)}
                  alt={imovel.data.titulo}
                  width={720}
                  widths={[440, 720, 1080]}
                  sizes="(max-width: 900px) 90vw, 360px"
                />
                <span class="selo">{tipoLabel[imovel.data.tipo]}</span>
                {imovel.data.codigo && <span class="selo-ref">{imovel.data.codigo}</span>}
              </div>
              <div class="card-corpo">
                <div class="onde">{eixoOcultaBairro(imovel.data.eixo) ? 'Condomínio fechado' : imovel.data.bairro}</div>
                <h3>{imovel.data.titulo}</h3>
                <div class="cota-mini card-cota">
                  <span class="haste"></span>
                  <span class="num">{imovel.data.areaUtil} m²</span>
                  <span class="haste"></span>
                </div>
                <div class="preco">
                  <span class="v num">{precoBR(imovel.data.preco)}</span>
                  <span class="ir">Ver detalhes →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SOBRE NÓS -->
  <section id="sobre">
    <div class="wrap">
      <div class="sobre">
        <div class="retrato reveal">
          <Image src={retratoMarcus} alt="Marcus Vinícius Costa, corretor de imóveis em Uberlândia" width={640} widths={[420, 640, 960]} sizes="(max-width: 820px) 90vw, 420px" />
        </div>
        <div class="reveal">
          <span class="rotulo rotulo-ciano">Sobre nós</span>
          <h2>Marcus Vinícius Costa</h2>
          <p>Marcus Vinícius Costa é um empreendedor uberlandense; marido, pai da Maria Eduarda, do Augusto e da caçula Lis; que atua no mercado imobiliário de médio e alto padrão desde o ano de 2020.</p>
          <p>De lá pra cá tem tido uma jornada de sucesso, realizando vários bons negócios para excelentes clientes! Esteve empreendendo desde seus 21 anos quando em 2002 abriu seu próprio negócio no ramo da Educação, Entretenimento e Lazer, com uma história de destaque até o encerramento das atividades em 2020, em virtude da pandemia.</p>
          <p>Trabalhar e ajudar pessoas sempre foi seu propósito, e quando isso não foi mais possível através do movimento, o destino colocou o mercado imobiliário à frente. Assim surgiu em 2020 a Portfólio Negócios Imobiliários, que vem fazendo um trabalho diferenciado junto às imobiliárias parceiras das quais já foi associado — como FR Imóveis de Luxo, Eccos Black, Taco, Diamond, Delta Sul e Polo Negócios, da qual hoje é corretor associado.</p>
          <p class="assinatura">Sejam bem-vindos!</p>

          <figure class="familia">
            <Image src={familiaMarcus} alt="Marcus com a esposa e os três filhos" width={520} widths={[360, 520, 780]} sizes="(max-width: 560px) 90vw, 290px" />
            <figcaption>Marcus com sua família na formatura de colegial da Dudinha em 2022</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <script is:inline set:html={`window.__IMOVEIS__ = ${JSON.stringify(dadosBusca)};
    window.__BAIRROS__ = ${JSON.stringify(bairrosConhecidos)};
    window.__EIXOS__ = ${JSON.stringify(eixosBusca)};`}></script>
  <script is:inline src="/busca.js"></script>
</Base>
