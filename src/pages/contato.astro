---
import Base from '../layouts/Base.astro';
import { CONTATO, waLink } from '../lib/site';

const WA = waLink('Olá Marcus, vim pelo site e gostaria de falar sobre um imóvel na Zona Sul.');
---

<Base
  title="Contato — Portfólio Negócios Imobiliários | Zona Sul de Uberlândia"
  description="Fale com o corretor Marcus Vinícius. Preencha o formulário ou chame no WhatsApp para agendar visitas e tirar dúvidas sobre imóveis na Zona Sul de Uberlândia."
>
  <div class="prop-head">
    <div class="wrap">
      <span class="rotulo rotulo-ciano">Fale com o corretor</span>
      <h1>Vamos conversar.</h1>
      <p class="eixo-lede">
        Deixe a gente entender melhor o que você procura ou mande a sua dúvida em relação aos
        imóveis que gostou. Envie o código de referência, pois com ele seu atendimento será
        muito mais rápido! Se desejar, coloque a forma como deseja ser contatado para receber
        as informações solicitadas.
      </p>
    </div>
  </div>

  <section style="border-top:none;padding-top:8px">
    <div class="wrap contato-grid">
      <div id="form-wrap">
        <form class="form-contato" id="form-contato">
          <div class="campo">
            <label for="nome">Seu nome</label>
            <input type="text" id="nome" name="nome" required />
          </div>
          <div class="form-linha">
            <div class="campo">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="campo">
              <label for="telefone">Telefone / WhatsApp</label>
              <input type="tel" id="telefone" name="telefone" />
            </div>
          </div>
          <div class="campo">
            <label for="mensagem">Mensagem</label>
            <textarea id="mensagem" name="mensagem" placeholder="Ex.: Gostei da casa CA1234 e CA5678 e gostaria de saber a quantos minutos à pé elas ficam do Praia?" required></textarea>
          </div>
          <button type="submit" class="btn btn-solido">Enviar mensagem</button>
          <p class="busca-dica" id="form-aviso" hidden></p>
        </form>

        <div class="form-sucesso" id="form-sucesso" hidden>
          <span class="icone-sucesso" aria-hidden="true">✓</span>
          <h2>Mensagem enviada!</h2>
          <p>Entraremos em contato o mais breve possível! Receba nossas boas vindas!</p>
        </div>
      </div>

      <aside class="contato-info">
        <h3>Portfólio Negócios Imobiliários</h3>
        <div class="contato-linha">
          <span class="rot">WhatsApp / Telefone</span>
          <a href={WA} target="_blank" rel="noopener">{CONTATO.whatsappLabel}</a>
        </div>
        <div class="contato-linha">
          <span class="rot">E-mail</span>
          <a href={`mailto:${CONTATO.email}`}>{CONTATO.email}</a>
        </div>
        <div class="contato-linha">
          <span class="rot">Instagram</span>
          <a href={CONTATO.instagram} target="_blank" rel="noopener">@marcus.imoveis</a>
        </div>
        <div class="contato-linha">
          <span class="rot">TikTok</span>
          <a href={CONTATO.tiktok} target="_blank" rel="noopener">@marcus.imoveis</a>
        </div>
        <div class="contato-linha">
          <span class="rot">Registro</span>
          <span>{CONTATO.creci} · {CONTATO.cnpj}</span>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('form-contato');
    const aviso = document.getElementById('form-aviso');
    const botao = form?.querySelector('button[type="submit"]');
    const sucesso = document.getElementById('form-sucesso');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const nome = document.getElementById('nome').value.trim();
      const mail = document.getElementById('email').value.trim();
      const tel = document.getElementById('telefone').value.trim();
      const msg = document.getElementById('mensagem').value.trim();

      // Pixel + CAPI: mesmo event_id nos dois lados, para deduplicação no Meta
      const eventId = 'lead_' + Date.now() + '_' + Math.random().toString(36).slice(2, 10);
      window.fbq && fbq('track', 'Lead', {}, { eventID: eventId });
      fetch('/api/capi', {
        method: 'POST',
        keepalive: true,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          event_name: 'Lead',
          event_id: eventId,
          event_source_url: window.location.href,
          contato: { email: mail, telefone: tel },
        }),
      }).catch(() => {});

      botao.disabled = true;
      aviso.hidden = false;
      aviso.textContent = 'Enviando sua mensagem…';

      try {
        const resposta = await fetch('/api/contato', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nome, email: mail, telefone: tel, mensagem: msg }),
        });
        const dados = await resposta.json().catch(() => ({}));

        if (resposta.ok && dados.ok) {
          form.hidden = true;
          sucesso.hidden = false;
          sucesso.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          aviso.textContent =
            'Não consegui enviar sua mensagem agora. Tente de novo em instantes ou chame no WhatsApp.';
        }
      } catch {
        aviso.textContent =
          'Não consegui enviar sua mensagem agora. Tente de novo em instantes ou chame no WhatsApp.';
      } finally {
        botao.disabled = false;
      }
    });
  </script>
</Base>
