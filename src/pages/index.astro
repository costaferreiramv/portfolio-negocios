---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { capaDe, precoBR } from '../lib/fotos';
import { SUBREGIOES, subregiaoDe, bairrosDoEixo } from '../lib/subregioes';
import retratoMarcus from '../assets/marcus/marcus-retrato.jpg';
import familiaMarcus from '../assets/marcus/marcus-familia.jpg';
import aereaZonaSul from '../assets/zonasul/parque-una-aerea.webp';

const WA_LINK =
  'https://wa.me/5534996396869?text=Ol%C3%A1%20Marcus%2C%20vim%20pelo%20site%20e%20gostaria%20de%20falar%20sobre%20um%20im%C3%B3vel%20na%20Zona%20Sul.';

const imoveis = (await getCollection('imoveis')).sort(
  (a, b) => b.data.publicadoEm.getTime() - a.data.publicadoEm.getTime()
);

// Agrupa os imóveis por eixo. Cada eixo conhece seus imóveis e seus bairros.
const eixos = SUBREGIOES.map((sr) => ({
  ...sr,
  bairros: bairrosDoEixo(sr.id),
  imoveis: imoveis.filter((im) => subregiaoDe(im.data.bairro) === sr.id),
}));
// Na vitrine, só entram eixos que têm imóvel — nunca um grupo vazio.
const eixosComImovel = eixos.filter((e) => e.imoveis.length > 0);
const totalBairros = Object.values(SUBREGIOES).length
  ? eixos.reduce((n, e) => n + e.bairros.length, 0)
  : 0;

const tipoLabel: Record<string, string> = {
  apartamento: 'Apartamento', casa: 'Casa', cobertura: 'Cobertura', lote: 'Lote',
};

const plural = (n: number, sing: string, plur: string) => (n === 1 ? sing : plur);
---

<Base
  title="Portfólio Negócios Imobiliários — Imóveis à venda na Zona Sul de Uberlândia"
  description="Curadoria de imóveis à venda na Zona Sul de Uberlândia, apresentada diretamente pelo corretor Marcus Vinícius. Atendimento direto, sem call center."
>
  <section class="hero">
    <div class="hero-prancha">
      <Image
        src={aereaZonaSul}
        alt="Vista aérea do Parque Una e da Zona Sul de Uberlândia"
        widths={[900, 1400, 2048]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-veu"></div>

      <div class="hero-conteudo">
        <div class="wrap">
          <div class="kicker reveal">
            <span class="risco"></span>
            <span class="rotulo rotulo-ciano">Zona Sul de Uberlândia</span>
          </div>

          <h1 class="reveal">
            Um território,
            <span class="leve">lido de perto.</span>
          </h1>

          <p class="lede reveal">
            Cada imóvel desta seleção foi escolhido um a um, dentro de um recorte
            de trinta e um bairros e condomínios. Você conversa direto com o
            corretor — e vê só o que merece a sua visita.
          </p>

          <div class="acoes reveal">
            <a class="btn btn-solido" href="#imoveis">Ver a seleção</a>
            <a class="btn btn-vazado" href={WA_LINK} target="_blank" rel="noopener">Falar no WhatsApp</a>
          </div>

          <div class="hero-cota reveal">
            <div class="cota">
              <span class="cota-linha"></span>
              <span class="cota-valor">{totalBairros} endereços · {SUBREGIOES.length} eixos</span>
              <span class="cota-linha"></span>
            </div>
            <div class="legenda">
              <span class="rotulo">{SUBREGIOES[0].nome}</span>
              <span class="rotulo">{SUBREGIOES[SUBREGIOES.length - 1].nome}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="curadoria">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="rotulo">Por que curadoria</span>
        <h2>Menos anúncios. Melhores decisões.</h2>
        <p>Comprar na Zona Sul não é rolar listas infinitas. É ter alguém que já andou a região inteira filtrando o que realmente merece a sua visita.</p>
      </div>
      <div class="pilares">
        <div class="pilar reveal">
          <span class="rotulo">Seleção</span>
          <h3>Escolhido pelo endereço</h3>
          <p>Cada imóvel entra pela localização dentro da Zona Sul — bairro e condomínio que sustentam o valor ao longo do tempo.</p>
        </div>
        <div class="pilar reveal">
          <span class="rotulo">Recorte</span>
          <h3>Só venda, só Zona Sul</h3>
          <p>Atuação concentrada em venda de imóveis na Zona Sul de Uberlândia. Você fala com o corretor, não com um call center.</p>
        </div>
        <div class="pilar reveal">
          <span class="rotulo">Método</span>
          <h3>Franqueza sobre o imóvel</h3>
          <p>Análise honesta de cada oportunidade, incluindo os pontos fracos. O objetivo é a sua melhor decisão, não a venda rápida.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="imoveis">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="rotulo">Seleção atual</span>
        <h2>Imóveis em destaque</h2>
        <p>Organizados pelo eixo da Zona Sul a que pertencem. Cada anúncio tem página própria, com todas as fotos e as informações que importam antes de uma visita.</p>
      </div>

      {eixosComImovel.map((eixo) => (
        <div class="grupo-eixo">
          <div class="grupo-cab reveal">
            <h3>{eixo.nome}</h3>
            <span class="cota-mini">
              <span class="haste"></span>
              <span class="num">{eixo.imoveis.length} {plural(eixo.imoveis.length, 'imóvel', 'imóveis')}</span>
            </span>
          </div>
          <div class="grade">
            {eixo.imoveis.map((imovel) => (
              <a class="card reveal" href={`/imovel/${imovel.id}/`}>
                <div class="foto">
                  <Image
                    src={capaDe(imovel.data.fotos, imovel.data.capa)}
                    alt={imovel.data.titulo}
                    width={720}
                    widths={[440, 720, 1080]}
                    sizes="(max-width: 900px) 90vw, 360px"
                  />
                  <span class="selo">{tipoLabel[imovel.data.tipo]}</span>
                </div>
                <div class="card-corpo">
                  <div class="onde">{imovel.data.bairro}</div>
                  <h3>{imovel.data.titulo}</h3>
                  <div class="cota-mini card-cota">
                    <span class="haste"></span>
                    <span class="num">{imovel.data.areaUtil} m²</span>
                    <span class="haste"></span>
                  </div>
                  <div class="preco">
                    <span class="v num">{precoBR(imovel.data.preco)}</span>
                    <span class="ir">Ver detalhes →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="zonasul">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="rotulo">Território de atuação</span>
        <h2>A Zona Sul, em {SUBREGIOES.length} eixos.</h2>
        <p>Em vez de uma lista infinita de bairros, o território é lido por eixos — cada um com um caráter próprio. Conhecer poucos a fundo vale mais do que anunciar a cidade inteira.</p>
      </div>

      <div class="eixos">
        {eixos.map((eixo) => (
          <article class="eixo reveal">
            <div class="eixo-topo">
              <h3>{eixo.nome}</h3>
              <span class="eixo-conta num">
                {eixo.imoveis.length > 0
                  ? `${eixo.imoveis.length} ${plural(eixo.imoveis.length, 'imóvel', 'imóveis')}`
                  : 'em prospecção'}
              </span>
            </div>
            <p class="eixo-desc">{eixo.descricao}</p>
            <div class="eixo-bairros">
              {eixo.bairros.map((b) => <span class="tag-bairro">{b}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="marcus">
    <div class="wrap">
      <div class="sobre">
        <div class="retrato reveal">
          <Image
            src={retratoMarcus}
            alt="Marcus Vinícius Costa, corretor de imóveis em Uberlândia"
            width={640}
            widths={[420, 640, 960]}
            sizes="(max-width: 820px) 90vw, 420px"
          />
        </div>
        <div class="reveal">
          <span class="rotulo">O corretor</span>
          <h2>Marcus Vinícius Costa</h2>
          <p>Empreendedor uberlandense, atuo no mercado imobiliário desde 2020. Antes disso, construí por quase vinte anos um negócio no ramo de educação e lazer — encerrado na pandemia. Trabalhar e ajudar pessoas sempre foi o propósito; mudou o meio, não o fim.</p>
          <p>Hoje sou corretor associado à Polo Negócios Imobiliários, depois de passar por empresas como FR Imóveis de Luxo, Eccos Black, Taco, Diamond e Delta Sul. Concentro minha atuação na Zona Sul de Uberlândia — conhecer profundamente uma região vale mais do que tentar vender a cidade inteira.</p>
          <p>É isso que me permite te mostrar o imóvel certo. E te dizer, com franqueza, quando um imóvel não é para você.</p>

          <figure class="familia">
            <Image
              src={familiaMarcus}
              alt="Marcus Vinícius Costa com a esposa e os três filhos"
              width={520}
              widths={[360, 520, 780]}
              sizes="(max-width: 560px) 90vw, 290px"
            />
            <figcaption>Com a esposa e os filhos Maria Eduarda, Augusto e Lis.</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <section id="contato" class="faixa">
    <div class="wrap dentro">
      <div>
        <span class="rotulo">Vamos conversar</span>
        <h2>Procurando na Zona Sul? Me diga o que você imagina.</h2>
        <p>Resposta direta, sem robô e sem enrolação. Atendimento por WhatsApp.</p>
      </div>
      <a class="btn-wa" href={WA_LINK} target="_blank" rel="noopener">WhatsApp · (34) 99639-6869</a>
    </div>
  </section>
</Base>
