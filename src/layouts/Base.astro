---
import '@fontsource-variable/archivo';
import '@fontsource-variable/literata';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import { Image, getImage } from 'astro:assets';
import logoNavy from '../assets/brand/logo-navy.png';
import logoWhite from '../assets/brand/logo-white.png';
import aereaSocial from '../assets/zonasul/zona-sul-1.png';
import { EIXOS } from '../lib/eixos';
import { CONTATO, waLink } from '../lib/site';

interface Props {
  title: string;
  description: string;
  /** URL absoluta da imagem social (og:image); default = aérea da Zona Sul */
  image?: string;
  ogType?: string;
  /** JSON-LD específico da página (objeto ou array) — injetado no <head> */
  jsonLd?: object | object[];
}
const { title, description, image, ogType = 'website', jsonLd } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const WA_GERAL = waLink('Olá Marcus, vim pelo site e gostaria de falar sobre um imóvel na Zona Sul.');

// imagem social padrão (aérea) e resolução para URL absoluta
const ogDefault = await getImage({ src: aereaSocial, width: 1200, format: 'jpg' });
const ogImage = new URL(image ?? ogDefault.src, Astro.site).href;
const logoAbs = new URL(logoNavy.src, Astro.site).href;

// schema de negócio local (site-wide) — sinal de marca + SEO local
const negocioLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: 'Portfólio Negócios Imobiliários',
  url: new URL('/', Astro.site).href,
  logo: logoAbs,
  image: ogImage,
  telephone: '+55' + CONTATO.whatsappNum.slice(2),
  areaServed: { '@type': 'City', name: 'Uberlândia' },
  address: { '@type': 'PostalAddress', addressLocality: 'Uberlândia', addressRegion: 'MG', addressCountry: 'BR' },
  sameAs: [CONTATO.instagram, CONTATO.tiktok],
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Portfólio Negócios Imobiliários',
  url: new URL('/', Astro.site).href,
  inLanguage: 'pt-BR',
};

// marca o item de menu ativo
const path = Astro.url.pathname;
const ehHome = path === '/' || path === '';
const ehZonaSul = path.startsWith('/zona-sul');
const ehContato = path.startsWith('/contato');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={logoNavy.src} />
    <link rel="apple-touch-icon" href={logoNavy.src} />
    <meta name="theme-color" content="#1e2a44" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Portfólio Negócios Imobiliários" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(negocioLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-in">
        <a class="brand" href="/" aria-label="Portfólio Negócios — página inicial">
          <Image class="brand-logo so-claro" src={logoNavy} alt="Portfólio Negócios Imobiliários" height={104} />
          <Image class="brand-logo so-escuro" src={logoWhite} alt="Portfólio Negócios Imobiliários" height={104} />
        </a>

        <nav class="nav-links" aria-label="Menu principal">
          <a href="/" class={ehHome ? 'ativo' : ''}>Home</a>

          <div class={`temsub ${ehZonaSul ? 'ativo' : ''}`}>
            <a href="/zona-sul/" class="sub-topo" aria-haspopup="true" aria-expanded="false">
              Zona Sul <span class="seta" aria-hidden="true">▾</span>
            </a>
            <div class="submenu">
              <a href="/zona-sul/"><strong>Eixos</strong><span>Como a Zona Sul se divide</span></a>
              {EIXOS.map((e) => (
                <a href={`/zona-sul/${e.id}/`}>{e.curto}</a>
              ))}
            </div>
          </div>

          <a href="/contato/" class={ehContato ? 'ativo' : ''}>Contato</a>
        </nav>

        <button class="nav-toggle" aria-label="Abrir menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="foot">
      <div class="wrap">
        <div class="foot-in">
          <div class="foot-marca">
            <Image class="logo so-claro" src={logoNavy} alt="Portfólio Negócios Imobiliários" height={176} />
            <Image class="logo so-escuro" src={logoWhite} alt="Portfólio Negócios Imobiliários" height={176} />
            <p class="muted">Curadoria de imóveis à venda na Zona Sul de Uberlândia — MG.</p>
          </div>

          <div class="foot-cols">
            <div>
              <h4 class="rotulo">Navegar</h4>
              <a href="/">Home</a>
              <a href="/zona-sul/">Zona Sul</a>
              <a href="/contato/">Contato</a>
            </div>
            <div>
              <h4 class="rotulo">Zona Sul</h4>
              {EIXOS.map((e) => <a href={`/zona-sul/${e.id}/`}>{e.curto}</a>)}
            </div>
            <div>
              <h4 class="rotulo">Contato</h4>
              <a href={WA_GERAL} target="_blank" rel="noopener">WhatsApp / Telefone {CONTATO.whatsappLabel}</a>
              <a href={`mailto:${CONTATO.email}`}>{CONTATO.email}</a>
              <a href={CONTATO.instagram} target="_blank" rel="noopener">Instagram @marcus.imoveis</a>
              <a href={CONTATO.tiktok} target="_blank" rel="noopener">TikTok @marcus.imoveis</a>
            </div>
          </div>
        </div>
        <div class="legal">
          <span class="rotulo">{CONTATO.razao} · {CONTATO.creci} · {CONTATO.cnpj}</span>
          <span class="rotulo">{CONTATO.cidade} · MMXXVI</span>
        </div>
      </div>
    </footer>

    <a class="wa-flutuante" href={WA_GERAL} target="_blank" rel="noopener" aria-label="Conversar no WhatsApp">
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" fill="currentColor">
        <path d="M16 3C9.4 3 4 8.4 4 15c0 2.1.6 4.2 1.6 6L4 29l8.2-1.6c1.8.9 3.8 1.4 5.8 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3zm0 21.8c-1.8 0-3.5-.5-5-1.4l-.4-.2-3.8.8.8-3.7-.2-.4c-1-1.6-1.5-3.4-1.5-5.3C5.9 9.9 10.5 5.3 16 5.3S26.1 9.9 26.1 15 21.5 24.8 16 24.8zm5.6-7.3c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.2-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.4z"/>
      </svg>
      <span>Fale no WhatsApp</span>
    </a>

    <script>
      // dropdown Zona Sul no mobile (clique) + menu hambúrguer
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const aberto = links?.classList.toggle('aberto');
        toggle.setAttribute('aria-expanded', String(!!aberto));
      });
      // no mobile, o item "Zona Sul" abre o submenu ao tocar na seta
      const sub = document.querySelector('.temsub');
      const subTopo = sub?.querySelector('.sub-topo');
      subTopo?.addEventListener('click', (e) => {
        if (window.matchMedia('(max-width: 860px)').matches) {
          e.preventDefault();
          sub?.classList.toggle('aberto');
        }
      });

      // revelação ao rolar
      const io = new IntersectionObserver(
        (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = Math.min(i, 5) * 45 + 'ms';
        io.observe(el);
      });
    </script>
  </body>
</html>
