---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { fotosDe, precoBR } from '../../lib/fotos';

export async function getStaticPaths() {
  const imoveis = await getCollection('imoveis');
  return imoveis.map((imovel) => ({
    params: { slug: imovel.id },
    props: { imovel },
  }));
}

const { imovel } = Astro.props;
const { Content } = await render(imovel);
const d = imovel.data;
const fotos = fotosDe(d.fotos, d.capa);
// versão grande otimizada para o link "abrir foto" (evita servir os originais de 4–5 MB)
const fotosGrandes = await Promise.all(
  fotos.map((foto) => getImage({ src: foto, width: 1800, format: 'webp' }))
);

const tipoLabel: Record<string, string> = {
  apartamento: 'Apartamento', casa: 'Casa', cobertura: 'Cobertura', lote: 'Lote',
};

const waMsg = encodeURIComponent(
  `Olá Marcus, vi no site o imóvel "${d.titulo}" (${d.bairro}) e gostaria de mais informações.`
);
const WA_LINK = `https://wa.me/5534996396869?text=${waMsg}`;

const descricaoMeta = `${tipoLabel[d.tipo]} à venda no ${d.bairro}, Uberlândia — ${d.areaUtil} m², ${d.suites} suítes, ${d.vagas} vagas. ${precoBR(d.preco)}. Direto com o corretor.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateListing',
  name: d.titulo,
  description: descricaoMeta,
  offers: {
    '@type': 'Offer',
    price: d.preco,
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Uberlândia',
    addressRegion: 'MG',
    addressCountry: 'BR',
  },
};
---

<Base title={`${d.titulo} — ${d.bairro}, Uberlândia | Portfólio Negócios`} description={descricaoMeta}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="prop-head">
    <div class="wrap">
      <span class="eyebrow">{tipoLabel[d.tipo]} · {d.bairro} · Zona Sul de Uberlândia</span>
      <h1>{d.titulo}</h1>
      <div class="prop-meta tnum">
        <span><b>{d.areaUtil} m²</b> área útil</span>
        <span><b>{d.suites}</b> suítes</span>
        <span><b>{d.vagas}</b> vagas</span>
        {d.condominio && <span>{d.condominio}</span>}
      </div>
      <div class="prop-price tnum">{precoBR(d.preco)}</div>
      <div class="prop-cta">
        <a class="btn-wa" href={WA_LINK} target="_blank" rel="noopener">Agendar visita pelo WhatsApp</a>
        <a class="btn btn-ghost" href="/#imoveis">← Voltar aos imóveis</a>
      </div>
    </div>
  </div>

  <section style="padding-top:0;border-top:none">
    <div class="wrap">
      <div class="galeria">
        {fotos.map((foto, i) => (
          <a href={fotosGrandes[i].src} target="_blank" rel="noopener">
            <Image
              src={foto}
              alt={`${d.titulo} — foto ${i + 1}`}
              width={i === 0 ? 1400 : 700}
              widths={i === 0 ? [700, 1100, 1400] : [400, 700]}
              sizes={i === 0 ? '(max-width: 820px) 100vw, 760px' : '(max-width: 820px) 50vw, 370px'}
              loading={i < 3 ? 'eager' : 'lazy'}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap prop-body">
      <div class="prosa">
        <Content />
      </div>
      <aside class="ficha">
        <h3>Ficha do imóvel</h3>
        <dl>
          <div class="row"><dt>Tipo</dt><dd>{tipoLabel[d.tipo]}</dd></div>
          <div class="row"><dt>Bairro</dt><dd>{d.bairro}</dd></div>
          {d.condominio && <div class="row"><dt>Condomínio</dt><dd>{d.condominio}</dd></div>}
          <div class="row"><dt>Área útil</dt><dd class="tnum">{d.areaUtil} m²</dd></div>
          <div class="row"><dt>Dormitórios</dt><dd class="tnum">{d.dormitorios} (todos suítes)</dd></div>
          <div class="row"><dt>Vagas</dt><dd class="tnum">{d.vagas}</dd></div>
          <div class="row"><dt>Financiamento</dt><dd>{d.aceitaFinanciamento ? 'Aceita' : 'Consultar'}</dd></div>
          <div class="row"><dt>Permuta</dt><dd>{d.aceitaPermuta ? 'Estuda' : 'Não'}</dd></div>
          <div class="row"><dt>Valor</dt><dd class="tnum">{precoBR(d.preco)}</dd></div>
        </dl>
        <a class="btn-wa" href={WA_LINK} target="_blank" rel="noopener">Falar com o Marcus</a>
      </aside>
    </div>
  </section>
</Base>
