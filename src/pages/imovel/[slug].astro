---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { fotosDe, precoBR } from '../../lib/fotos';
import { waLink } from '../../lib/site';
import { eixoOcultaBairro } from '../../lib/eixos';

export async function getStaticPaths() {
  const imoveis = await getCollection('imoveis');
  return imoveis.map((imovel) => ({
    params: { slug: imovel.id },
    props: { imovel },
  }));
}

const { imovel } = Astro.props;
const { Content } = await render(imovel);
const d = imovel.data;
const fotos = fotosDe(d.fotos, d.capa);

// capa grande e miniaturas otimizadas; versão 1600px para o lightbox
const capaImg = await getImage({ src: fotos[0], width: 1400, widths: [760, 1100, 1400], format: 'webp' });
const minis = await Promise.all(
  fotos.map((f) => getImage({ src: f, width: 300, widths: [180, 300], format: 'webp' }))
);
const grandes = await Promise.all(
  fotos.map((f) => getImage({ src: f, width: 1600, format: 'webp' }))
);
const urlsGrandes = grandes.map((g) => g.src);

const tipoLabel: Record<string, string> = {
  apartamento: 'Apartamento', casa: 'Casa', cobertura: 'Cobertura', lote: 'Lote',
  'sala-comercial': 'Sala comercial', 'casa-comercial': 'Casa comercial',
  area: 'Área', fazenda: 'Fazenda', rancho: 'Rancho', sitio: 'Sítio',
};

// Eixo de condomínios: o bairro não aparece em lugar nenhum (regra do eixo).
const ocultaBairro = eixoOcultaBairro(d.eixo);
// Rótulo de localização usado no lugar do bairro quando ele fica oculto.
const local = ocultaBairro ? 'Condomínio fechado' : d.bairro;

const WA_LINK = waLink(`Olá Marcus, vi no site o imóvel "${d.titulo}" e gostaria de sanar uma dúvida.`);

const descricaoMeta = ocultaBairro
  ? `${tipoLabel[d.tipo]} à venda em condomínio fechado na Zona Sul de Uberlândia — ${d.areaUtil} m², ${d.suites} suítes, ${d.vagas} vagas. ${precoBR(d.preco)}. Direto com o corretor.`
  : `${tipoLabel[d.tipo]} à venda no ${d.bairro}, Uberlândia — ${d.areaUtil} m², ${d.suites} suítes, ${d.vagas} vagas. ${precoBR(d.preco)}. Direto com o corretor.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateListing',
  name: d.titulo,
  description: descricaoMeta,
  offers: { '@type': 'Offer', price: d.preco, priceCurrency: 'BRL', availability: 'https://schema.org/InStock' },
  address: { '@type': 'PostalAddress', addressLocality: 'Uberlândia', addressRegion: 'MG', addressCountry: 'BR' },
};
---

<Base title={`${d.titulo} — ${ocultaBairro ? 'Zona Sul' : d.bairro}, Uberlândia | Portfólio Negócios`} description={descricaoMeta}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="prop-topo" style="border-top:none">
    <div class="wrap">
      <a class="rotulo rotulo-ciano prop-voltar" href="/zona-sul/">← Zona Sul · {tipoLabel[d.tipo]} · {local}{d.codigo ? ` · Ref. ${d.codigo}` : ''}</a>

      <div class="prop-layout">
        <!-- GALERIA (lateral): capa + miniaturas -->
        <div class="prop-galeria">
          <button class="capa" data-i="0" aria-label="Ampliar foto de capa">
            <img src={capaImg.src} srcset={capaImg.srcSet.attribute} sizes="(max-width:920px) 100vw, 620px" alt={`${d.titulo} — foto 1`} loading="eager" />
            <span class="capa-lupa" aria-hidden="true">⤢ ver fotos</span>
          </button>
          <div class="miniaturas">
            {minis.map((m, i) => (
              <button class="mini" data-i={i} aria-label={`Ver foto ${i + 1}`}>
                <img src={m.src} srcset={m.srcSet.attribute} sizes="120px" alt={`${d.titulo} — miniatura ${i + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        <!-- INFORMAÇÕES (ao lado) -->
        <div class="prop-info">
          <h1>{d.titulo}</h1>
          <div class="prop-preco">{precoBR(d.preco)}</div>

          <div class="prop-cotas">
            <div class="c"><div class="v">{d.areaUtil} m²</div><div class="l rotulo">{d.areaTerreno ? 'Construída' : 'Área útil'}</div></div>
            {d.areaTerreno && <div class="c"><div class="v">{d.areaTerreno} m²</div><div class="l rotulo">Terreno</div></div>}
            <div class="c"><div class="v">{d.suites}</div><div class="l rotulo">Suítes</div></div>
            <div class="c"><div class="v">{d.vagas}</div><div class="l rotulo">Vagas</div></div>
            <div class="c"><div class="v">{d.dormitorios}</div><div class="l rotulo">Dormitórios</div></div>
          </div>

          <div class="prop-cta-dupla">
            <a class="btn btn-solido" href="/contato/">Agendar uma Visita</a>
            <a class="btn-wa" href={WA_LINK} target="_blank" rel="noopener">Sanar dúvida no WhatsApp</a>
          </div>

          <div class="prosa">
            <Content />
          </div>

          <aside class="ficha">
            <h3>Ficha do imóvel</h3>
            <span class="rotulo">Dados declarados pelo proprietário</span>
            <dl>
              {d.codigo && <div class="linha"><dt>Referência</dt><dd class="ref-codigo">{d.codigo}</dd></div>}
              <div class="linha"><dt>Tipo</dt><dd>{tipoLabel[d.tipo]}</dd></div>
              {!ocultaBairro && <div class="linha"><dt>Bairro</dt><dd>{d.bairro}</dd></div>}
              {d.condominio && <div class="linha"><dt>Condomínio</dt><dd>{d.condominio}</dd></div>}
              <div class="linha"><dt>{d.areaTerreno ? 'Área construída' : 'Área útil'}</dt><dd>{d.areaUtil} m²</dd></div>
              {d.areaTerreno && <div class="linha"><dt>Área do terreno</dt><dd>{d.areaTerreno} m²</dd></div>}
              {d.dormitorios > 0 && (
                <div class="linha">
                  <dt>Dormitórios</dt>
                  <dd>{d.dormitorios}{d.suites === d.dormitorios ? ' (todas suítes)' : d.suites > 0 ? ` (${d.suites} ${d.suites === 1 ? 'suíte' : 'suítes'})` : ''}</dd>
                </div>
              )}
              {d.vagas > 0 && <div class="linha"><dt>Vagas</dt><dd>{d.vagas}</dd></div>}
              {d.aceitaFinanciamento !== undefined && <div class="linha"><dt>Financiamento</dt><dd>{d.aceitaFinanciamento ? 'Aceita' : 'Não aceita'}</dd></div>}
              {d.aceitaPermuta !== undefined && <div class="linha"><dt>Permuta</dt><dd>{d.aceitaPermuta ? 'Estuda' : 'Não'}</dd></div>}
              <div class="linha"><dt>Valor</dt><dd>{precoBR(d.preco)}</dd></div>
            </dl>
          </aside>

          <div class="prop-cta-dupla rodape">
            <a class="btn btn-solido" href="/contato/">Agendar uma Visita</a>
            <a class="btn-wa" href={WA_LINK} target="_blank" rel="noopener">Sanar dúvida no WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox" hidden>
    <button class="lb-fechar" id="lb-fechar" aria-label="Fechar">✕</button>
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="Foto anterior">‹</button>
    <img class="lb-img" id="lb-img" src="" alt="" />
    <button class="lb-nav lb-next" id="lb-next" aria-label="Próxima foto">›</button>
    <span class="lb-contador" id="lb-contador"></span>
  </div>

  <script is:inline define:vars={{ urls: urlsGrandes, titulo: d.titulo }}>
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lb-img');
    const contador = document.getElementById('lb-contador');
    let idx = 0;
    function mostra(i) {
      idx = (i + urls.length) % urls.length;
      lbImg.src = urls[idx];
      lbImg.alt = titulo + ' — foto ' + (idx + 1);
      contador.textContent = (idx + 1) + ' / ' + urls.length;
    }
    function abre(i) { mostra(i); lb.hidden = false; document.body.style.overflow = 'hidden'; }
    function fecha() { lb.hidden = true; document.body.style.overflow = ''; }
    document.querySelectorAll('[data-i]').forEach((el) => {
      el.addEventListener('click', () => abre(parseInt(el.getAttribute('data-i'), 10)));
    });
    document.getElementById('lb-fechar').addEventListener('click', fecha);
    document.getElementById('lb-prev').addEventListener('click', () => mostra(idx - 1));
    document.getElementById('lb-next').addEventListener('click', () => mostra(idx + 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) fecha(); });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') fecha();
      if (e.key === 'ArrowLeft') mostra(idx - 1);
      if (e.key === 'ArrowRight') mostra(idx + 1);
    });
  </script>
</Base>
