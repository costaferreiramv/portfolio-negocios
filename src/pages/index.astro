---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { capaDe, precoBR } from '../lib/fotos';
import { EIXOS, eixoOcultaBairro } from '../lib/eixos';
import { imagemZonaSul, waLink } from '../lib/site';
import retratoMarcus from '../assets/marcus/marcus-retrato.jpg';
import familiaMarcus from '../assets/marcus/marcus-familia.jpg';
import aereaZonaSul from '../assets/zonasul/zona-sul-home-bg.png';

const imoveis = (await getCollection('imoveis')).sort(
  (a, b) => b.data.publicadoEm.getTime() - a.data.publicadoEm.getTime()
);

// Dados de busca embutidos: cada imóvel com a capa já otimizada (para o JS montar os cards).
const dadosBusca = await Promise.all(
  imoveis.map(async (im) => {
    const capa = await getImage({
      src: capaDe(im.data.fotos, im.data.capa),
      width: 720,
      widths: [440, 720],
      format: 'webp',
    });
    return {
      slug: im.id,
      titulo: im.data.titulo,
      tipo: im.data.tipo,
      // bairro só embarcado quando o eixo permite exibi-lo — não vaza no HTML dos condomínios
      bairro: eixoOcultaBairro(im.data.eixo) ? '' : im.data.bairro,
      eixo: im.data.eixo,
      ocultaBairro: eixoOcultaBairro(im.data.eixo),
      condominio: !!im.data.condominio,
      preco: im.data.preco,
      area: im.data.areaUtil,
      dormitorios: im.data.dormitorios,
      suites: im.data.suites,
      vagas: im.data.vagas,
      capa: capa.src,
      url: `/imovel/${im.id}/`,
    };
  })
);

// bairros/áreas que a busca reconhece (dos eixos + dos imóveis cadastrados).
// Imóveis de eixo com bairro oculto não contribuem seu bairro — nem como termo reconhecido.
const bairrosConhecidos = Array.from(
  new Set([
    ...EIXOS.flatMap((e) => e.areas),
    ...imoveis.filter((i) => !eixoOcultaBairro(i.data.eixo)).map((i) => i.data.bairro),
  ])
);

// eixos (id + áreas) para a busca resolver "perto de X" pela região, não só pelo bairro exato
const eixosBusca = EIXOS.map((e) => ({ id: e.id, nome: e.curto, areas: e.areas }));

const WA_BUSCA = waLink('Olá Marcus, não encontrei no site exatamente o que procuro. Pode me ajudar?');

// eixos com imagem otimizada
const eixosImg = await Promise.all(
  EIXOS.map(async (e) => ({
    ...e,
    img: await getImage({ src: imagemZonaSul(e.imagem), width: 720, widths: [440, 720], format: 'webp' }),
  }))
);
---

<Base
  title="Portfólio Negócios Imobiliários — Imóveis à venda na Zona Sul de Uberlândia"
  description="Curadoria de imóveis à venda na Zona Sul de Uberlândia, apresentada diretamente pelo corretor Marcus Vinícius. Busque em linguagem natural e fale direto com o corretor."
>
  <!-- HERO: forma de trabalhar + busca livre -->
  <section class="hero-busca">
    <div class="hero-bg">
      <Image src={aereaZonaSul} alt="Vista aérea da Zona Sul de Uberlândia" widths={[900, 1400, 2048]} sizes="100vw" loading="eager" fetchpriority="high" />
      <div class="hero-veu2"></div>
    </div>
    <div class="wrap hero-busca-in">
      <span class="rotulo rotulo-ciano reveal">Zona Sul de Uberlândia</span>
      <h1 class="reveal hero-busca-titulo">Imóveis selecionados, escolhas inteligentes.</h1>
      <p class="lede reveal">
        Nossa curadoria elimina o ruído, focando no que é essencial para você. Menos busca, mais acerto. Escreva aqui o que procura, com suas palavras, clique em buscar e surpreenda-se.
      </p>

      <form class="busca reveal" id="form-busca" role="search">
        <input
          type="text" id="q" name="q" autocomplete="off"
          placeholder="Ex.: casa de 3 quartos na Zona Sul, entre 870 mil e 1,2 milhões, 120 m²+"
          aria-label="Descreva o imóvel que procura"
        />
        <button type="submit">Buscar</button>
      </form>
      <p class="busca-dica reveal">Escreva livremente: tipo, bairro ou eixo, nº de quartos/suítes, faixa de preço e área.</p>
    </div>
  </section>

  <!-- RESULTADOS da busca (preenchidos por JS) -->
  <section id="resultados" hidden>
    <div class="wrap">
      <div class="res-cab">
        <div>
          <span class="rotulo">Resultado da busca</span>
          <h2 id="res-titulo">Imóveis encontrados</h2>
          <p id="res-interp" class="res-interp"></p>
        </div>
        <button id="limpar" class="btn btn-vazado" type="button">Limpar busca</button>
      </div>
      <div class="grade" id="res-grade"></div>
      <div id="res-vazio" class="res-vazio" hidden>
        <p>Não achei um imóvel que bata exatamente com isso na seleção atual — mas o estoque muda o tempo todo. Me conte o que procura que eu busco pra você.</p>
        <a class="btn-wa" href={WA_BUSCA} target="_blank" rel="noopener">Falar com o Marcus</a>
      </div>
    </div>
  </section>

  <!-- ESPECIALIDADE: Zona Sul e seus eixos -->
  <section id="zonasul-home">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="rotulo rotulo-ciano">Nossa especialidade</span>
        <h2>A Zona Sul em foco.</h2>
        <p>Nos especializamos na região da Zona Sul, segmentamos cada parte e conhecemos a fundo cada imóvel do portfólio para proporcionar a cada vendedor e comprador a melhor experiência de atendimento.</p>
      </div>
      <div class="eixos-img">
        {eixosImg.map((e) => (
          <a class="eixo-card reveal" href={`/zona-sul/${e.id}/`}>
            <div class="eixo-foto">
              <img src={e.img.src} srcset={e.img.srcSet.attribute} sizes="(max-width:760px) 90vw, 380px" alt={`Zona Sul — ${e.nome}`} loading="lazy" />
            </div>
            <div class="eixo-card-corpo">
              <h3>{e.nome}</h3>
              <span class="eixo-ir">Ver imóveis do eixo →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="reveal" style="margin-top:32px">
        <a class="btn btn-vazado" href="/zona-sul/">Entender a divisão por eixos</a>
      </div>
    </div>
  </section>

  <!-- SOBRE NÓS -->
  <section id="sobre">
    <div class="wrap">
      <div class="sobre">
        <div class="retrato reveal">
          <Image src={retratoMarcus} alt="Marcus Vinícius Costa, corretor de imóveis em Uberlândia" width={640} widths={[420, 640, 960]} sizes="(max-width: 820px) 90vw, 420px" />
        </div>
        <div class="reveal">
          <span class="rotulo rotulo-ciano">Sobre nós</span>
          <h2>Marcus Vinícius Costa</h2>
          <p>Marcus Vinícius Costa é um empreendedor uberlandense; marido, pai da Maria Eduarda, do Augusto e da caçula Lis; que atua no mercado imobiliário de médio e alto padrão desde o ano de 2020.</p>
          <p>De lá pra cá tem tido uma jornada de sucesso, realizando vários bons negócios para excelentes clientes! Esteve empreendendo desde seus 21 anos quando em 2002 abriu seu próprio negócio no ramo da Educação, Entretenimento e Lazer, com uma história de destaque até o encerramento das atividades em 2020, em virtude da pandemia.</p>
          <p>Trabalhar e ajudar pessoas sempre foi seu propósito, e quando isso não foi mais possível através do movimento, o destino colocou o mercado imobiliário à frente. Assim surgiu em 2020 a Portfólio Negócios Imobiliários, que vem fazendo um trabalho diferenciado junto às imobiliárias parceiras das quais já foi associado — como FR Imóveis de Luxo, Eccos Black, Taco, Diamond, Delta Sul e Polo Negócios, da qual hoje é corretor associado.</p>
          <p class="assinatura">Sejam bem-vindos!</p>

          <figure class="familia">
            <Image src={familiaMarcus} alt="Marcus com a esposa e os três filhos" width={520} widths={[360, 520, 780]} sizes="(max-width: 560px) 90vw, 290px" />
            <figcaption>Com a esposa e os filhos Maria Eduarda, Augusto e Lis.</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <script is:inline set:html={`window.__IMOVEIS__ = ${JSON.stringify(dadosBusca)};
    window.__BAIRROS__ = ${JSON.stringify(bairrosConhecidos)};
    window.__EIXOS__ = ${JSON.stringify(eixosBusca)};`}></script>
  <script is:inline src="/busca.js"></script>
</Base>
